# GEMINI_API_KEY: Required for Gemini AI API calls.
# This can be injected at runtime from your deployment secrets.
# Configure this in your hosting platform's environment settings.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This can be injected at runtime with your deployed service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
